---
import Footer from "@components/common/Footer.astro";
import Head from "@components/common/Head.astro";
import Navbar from "@components/common/Navbar";

import "@fontsource-variable/raleway";
import "@styles/tailwind.css";

const {
  lang,
  title,
  description,
  canonical,
  alternateEs,
  alternateEn,
  breadcrumbJsonLd,
} = Astro.props;
---

<html lang={lang}>
  <Head
    title={title}
    description={description}
    canonical={canonical}
    alternateEs={alternateEs}
    alternateEn={alternateEn}
    lang={lang}
    breadcrumbJsonLd={breadcrumbJsonLd}
  />
  <body
    class="from-fgreen/20 to-fpurple/40 flex min-h-screen w-full flex-col bg-black bg-gradient-to-br antialiased"
  >
    <Navbar lang={lang} client:load />
    <slot />
    <Footer lang={lang} />
  </body>
</html>
