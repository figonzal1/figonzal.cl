---
import { FaGithub } from "react-icons/fa6";
import { ImFacebook, ImLinkedin2 } from "react-icons/im";
import { SiGoogleplay, SiInstagram } from "react-icons/si";
import SocialLink from "./SocialLink.astro";

const { titles, subTitles } = Astro.props;
---

<section>
  <div class="px-10 py-14">
    <h1 class="text-center text-2xl font-medium text-white md:text-4xl">
      {titles[0]}
      <span class="text-fgreen font-medium">{titles[1]}</span>
    </h1>

    <p class="py-3 text-center text-white">
      {subTitles[0]}
      <span class="text-fgreen">{subTitles[1]}</span>
      {subTitles[2]}
    </p>

    <div
      class="flex flex-wrap items-center justify-center gap-3 py-4 md:gap-6 md:py-8"
    >
      <SocialLink icon={FaGithub} link="https://github.com/figonzal1" />

      <SocialLink
        icon={SiGoogleplay}
        link="https://play.google.com/store/apps/dev?id=4650587366054768148"
      />

      <SocialLink
        icon={SiInstagram}
        link="https://www.instagram.com/figonzal.cl"
      />

      <SocialLink icon={ImFacebook} link="https://facebook.com/figonzal1" />

      <SocialLink
        icon={ImLinkedin2}
        link="https://www.linkedin.com/in/figonzal/"
      />
    </div>
  </div>
</section>
