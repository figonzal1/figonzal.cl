---
import PurpleButton from "@components/common/PurpleButton.astro";
import type {
  ProjectProp,
  ProjectButton,
  ProjectCategory,
} from "src/utils/types";
import ProjectCard from "./ProjectCard.astro";

interface Props {
  title: [string, string];
  projects: ProjectProp[];
  lang: string;
  activeCategory: ProjectCategory;
}

const { title, projects, lang, activeCategory } = Astro.props;

const tabs: { category: ProjectCategory; label: string; href: string }[] = [
  {
    category: "web",
    label: "Web",
    href: lang === "es" ? "/proyectos/web" : "/en/projects/web",
  },
  {
    category: "mobile",
    label: lang === "es" ? "Móvil" : "Mobile",
    href: lang === "es" ? "/proyectos/movil" : "/en/projects/mobile",
  },
];

const filteredProjects = projects.filter(
  (project) => project.category === activeCategory,
);

const emptyMessage =
  lang === "es"
    ? "Pronto agregaré proyectos en esta categoría."
    : "I will add projects to this category soon.";
---

<section class="mb-auto">
  <div class="py-40">
    <h1 class="text-center text-2xl font-medium text-white sm:text-4xl">
      {title[0]}
      <span class="text-fgreen font-medium">{title[1]}</span>
    </h1>

    <nav class="mt-10 flex justify-center gap-4" aria-label={title.join(" ")}>
      {
        tabs.map((tab) => {
          const isActive = tab.category === activeCategory;
          return (
            <a
              href={tab.href}
              aria-current={isActive ? "page" : undefined}
              class:list={[
                "rounded-lg border-2 px-6 py-2 font-medium transition-colors duration-150 ease-in-out",
                isActive
                  ? "border-fgreen bg-fgreen/10 text-fgreen"
                  : "border-fpurple hover:bg-fpurple/30 text-white",
              ]}
            >
              {tab.label}
            </a>
          );
        })
      }
    </nav>

    {
      filteredProjects.length > 0 ? (
        <div class="grid grid-cols-1 gap-10 p-10 sm:p-24 lg:grid-cols-2 lg:p-24 2xl:grid-cols-3">
          {filteredProjects.map((project: ProjectProp) => {
            const cardTitle = lang === "es" ? project.nameEs : project.nameEn;
            const description =
              lang === "es" ? project.descriptionEs : project.descriptionEn;

            return (
              <ProjectCard
                title={cardTitle}
                description={description}
                coverImage={project.coverImage}
                techStack={project.techStack}
              >
                {project.buttonLinks.map((button: ProjectButton) => (
                  <PurpleButton
                    title={button.title}
                    link={button.link}
                    icon={button.icon}
                  />
                ))}
              </ProjectCard>
            );
          })}
        </div>
      ) : (
        <p class="mt-16 text-center font-mono text-white/70">{emptyMessage}</p>
      )
    }
  </div>
</section>
