---
const { title, link, icon: Icon } = Astro.props;
---

<a
  class="border-fpurple bg-fpurple-box hover:bg-fpurple/30 flex items-center justify-center gap-1 rounded-lg border-2 p-2 px-4 py-2 transition-colors duration-150 ease-in-out"
  href={link}
  target="_blank"
  referrerpolicy="no-referrer"
>
  <Icon color="white" size={21} alt={title} />
  <div class="hidden sm:block">
    <h2 class="ps-1 text-white">{title}</h2>
  </div>
</a>
