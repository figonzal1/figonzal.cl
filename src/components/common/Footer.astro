---
import { FaGithub } from "react-icons/fa6";
import { ImFacebook, ImLinkedin2 } from "react-icons/im";
import { SiGoogleplay, SiInstagram } from "react-icons/si";
import { Picture } from "astro:assets";
import logo from "@assets/images/logo.png";

const { lang } = Astro.props;

let footerMsg = "";
if (lang === "es") {
  footerMsg = "Hecho con 🍵 y código por ";
} else {
  footerMsg = "Made with 🍵 & code by ";
}
---

<footer class="bg-fpurple/20 w-full backdrop-blur-sm">
  <div class="px-8 py-4 text-white">
    <div
      class="flex flex-col items-center justify-center gap-5 sm:flex-row sm:justify-between"
    >
      <a href="https://www.figonzal.cl/" aria-label="Inicio Figonzal.cl">
        <Picture
          src={logo}
          formats={["webp"]}
          fallbackFormat="png"
          height={32}
          alt="Figonzal.cl Logo"
          loading="lazy"
          decoding="async"
        />
      </a>

      <div class="flex items-center justify-center gap-5">
        <a
          href="https://github.com/figonzal1"
          target="_blank"
          rel="noreferrer"
          class="transition-opacity duration-150 ease-in-out hover:opacity-50"
        >
          <FaGithub />
        </a>

        <a
          href="https://play.google.com/store/apps/dev?id=4650587366054768148"
          target="_blank"
          rel="noreferrer"
          class="transition-opacity duration-150 ease-in-out hover:opacity-50"
        >
          <SiGoogleplay />
        </a>

        <a
          href="https://www.instagram.com/figonzal.cl"
          target="_blank"
          rel="noreferrer"
          class="transition-opacity duration-150 ease-in-out hover:opacity-50"
        >
          <SiInstagram />
        </a>

        <a
          href="https://facebook.com/figonzal.cl"
          target="_blank"
          rel="noreferrer"
          class="transition-opacity duration-150 ease-in-out hover:opacity-50"
        >
          <ImFacebook />
        </a>

        <a
          href="https://www.linkedin.com/in/figonzal/"
          target="_blank"
          rel="noreferrer"
          class="transition-opacity duration-150 ease-in-out hover:opacity-50"
        >
          <ImLinkedin2 />
        </a>
      </div>
    </div>

    <hr class="border-fpurple/30 my-4 rounded-full" />

    <span class="flex flex-col justify-center text-center text-sm">
      <span id="year"></span>
      <span
        >{footerMsg}<a
          href="https://figonzal.cl/"
          class="font-semibold underline transition-opacity duration-150 ease-in-out hover:opacity-50"
          >figonzal.cl</a
        >
      </span>
    </span>
  </div>

  <script>
    const actualYear = new Date().getFullYear();
    const yearElement = document.getElementById("year");

    if (yearElement) {
      yearElement.textContent = actualYear.toString();
    } else {
      console.log('No se encontró el elemento con id "year"');
    }
  </script>
</footer>
