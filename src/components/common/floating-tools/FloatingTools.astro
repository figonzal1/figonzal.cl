---
import type { ProjectStack } from "@utils/types";
import FloatingIconTool from "./FloatingIconTool.astro";

const { techStack } = Astro.props;
---

<div
  class="border-fgreen/90 bg-fpurple shadow-fpurple-box absolute right-4 -bottom-3 rounded-lg border-2 opacity-0 shadow-md transition-all delay-150 duration-300 ease-in-out group-hover:opacity-85 sm:opacity-85 2xl:opacity-0"
>
  <div class="flex flex-row gap-3 p-1">
    {
      techStack.map((item: ProjectStack) => (
        <FloatingIconTool title={item.title} icon={item.icon} />
      ))
    }
  </div>
</div>
