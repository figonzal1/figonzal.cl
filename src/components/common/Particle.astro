<div id="tsparticles"></div>

<script>
  import { type ISourceOptions, tsParticles } from "@tsparticles/engine";
  import { loadAll } from "@tsparticles/all";

  const options: ISourceOptions = {
    detectRetina: true,
    fullScreen: {
      zIndex: -1,
    },
    particles: {
      number: {
        value: 80,
        density: {
          enable: true,
        },
      },
      links: {
        enable: true,
        distance: 150,
        opacity: 0.1,
        width: 1,
      },
      move: {
        enable: true,
        speed: 0.5,
        direction: "none",
        outModes: "out",
      },
      size: {
        value: 1,
      },
      opacity: {
        animation: {
          enable: true,
          speed: 1,
        },
      },
    },
  };

  let loaded = false;
  let container: Awaited<ReturnType<typeof tsParticles.load>>;

  async function initParticles() {
    // Limpia la instancia previa: evita duplicados y partículas
    // remanentes al navegar a una página que no las usa.
    container?.destroy();
    container = undefined;

    // Particle no está en todas las páginas: solo recrea si hay contenedor.
    if (!document.getElementById("tsparticles")) return;

    if (!loaded) {
      await loadAll(tsParticles);
      loaded = true;
    }

    container = await tsParticles.load({ id: "tsparticles", options });
  }

  // Dispara en la carga inicial y tras cada view transition
  document.addEventListener("astro:page-load", () => void initParticles());
</script>
