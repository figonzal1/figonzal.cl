---
import Particle from "@components/common/Particle.astro";
import AbstractSection from "@components/home/AbstractSection.astro";
import FeaturedProjects from "@components/home/FeaturedProjects.astro";
import IntroSection from "@components/home/IntroSection.astro";
import SocialSection from "@components/home/socialsection/SocialSection.astro";
import TechStackSection from "@components/home/techsection/TechStackSection.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { githubMonthLabels } from "src/utils/translations";
---

<BaseLayout
  lang="es"
  canonical="https://www.figonzal.cl/"
  alternateEs="https://www.figonzal.cl/"
  alternateEn="https://www.figonzal.cl/en"
>
  <div class="h-0 w-0">
    <Particle />
  </div>
  <IntroSection
    hello="Hola"
    im="Soy"
    typeWritter={[
      "Apasionado por la tecnología e innovación",
      "Desarrollador Android & AR",
      "Ingeniero Informático",
      "Colaborador Open Source",
    ]}
  />
  <AbstractSection />
  <FeaturedProjects
    title={["Proyectos", "Destacados"]}
    lang="es"
    ctaLabel="Ver todos los proyectos"
    ctaHref="/proyectos/web"
  />
  <TechStackSection
    languagesTitle={["Lenguajes de", "Programación"]}
    frameworksTitle={["Frameworks y", "Plataformas"]}
    toolsTitle={["Herramientas de", "Desarrollo"]}
    devopsTitle={["Cloud y", "DevOps"]}
    ghTitle={["Días", "Codeando"]}
    commitMsg="commits en"
    labels={githubMonthLabels}
  />
  <SocialSection
    titles={["Mis", "Redes"]}
    subTitles={["Siéntase libre de", "conectarse", "conmigo"]}
  />
</BaseLayout>
