---
import Particle from "@components/common/Particle.astro";
import ProjectSection from "@components/projects/ProjectSection.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { projectSeeder } from "src/utils/seeders/projectSeeder";

const lang = "es";
---

<BaseLayout
  lang={lang}
  title="Proyectos Móviles | figonzal.cl"
  description="Aplicaciones móviles Android desarrolladas por Felipe González."
  canonical="https://www.figonzal.cl/proyectos/movil"
>
  <div class="h-0 w-0">
    <Particle />
  </div>
  <ProjectSection
    title={["Proyectos", "Móviles"]}
    projects={projectSeeder}
    lang={lang}
    activeCategory="mobile"
  />
</BaseLayout>
