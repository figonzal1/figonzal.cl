---
import Particle from "@components/common/Particle.astro";
import ProjectSection from "@components/projects/ProjectSection.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { projectSeeder } from "src/utils/seeders/projectSeeder";

const lang = "es";

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Inicio",
      item: "https://www.figonzal.cl/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Proyectos Web",
      item: "https://www.figonzal.cl/proyectos/web",
    },
  ],
};
---

<BaseLayout
  lang={lang}
  title="Proyectos Web | figonzal.cl"
  description="Proyectos web desarrollados por Felipe González: aplicaciones y sitios web."
  canonical="https://www.figonzal.cl/proyectos/web"
  alternateEs="https://www.figonzal.cl/proyectos/web"
  alternateEn="https://www.figonzal.cl/en/projects/web"
  breadcrumbJsonLd={breadcrumbJsonLd}
>
  <div class="h-0 w-0">
    <Particle />
  </div>
  <ProjectSection
    title={["Proyectos", "Web"]}
    projects={projectSeeder}
    lang={lang}
    activeCategory="web"
  />
</BaseLayout>
