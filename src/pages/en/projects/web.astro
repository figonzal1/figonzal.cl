---
import Particle from "@components/common/Particle.astro";
import ProjectSection from "@components/projects/ProjectSection.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { projectSeeder } from "src/utils/seeders/projectSeeder";

const lang = "en";

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://www.figonzal.cl/en",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Web Projects",
      item: "https://www.figonzal.cl/en/projects/web",
    },
  ],
};
---

<BaseLayout
  lang={lang}
  title="Web Projects | figonzal.cl"
  description="Web projects developed by Felipe González: web applications and websites."
  canonical="https://www.figonzal.cl/en/projects/web"
  alternateEs="https://www.figonzal.cl/proyectos/web"
  alternateEn="https://www.figonzal.cl/en/projects/web"
  breadcrumbJsonLd={breadcrumbJsonLd}
>
  <div class="h-0 w-0">
    <Particle />
  </div>
  <ProjectSection
    title={["Web", "Projects"]}
    projects={projectSeeder}
    lang={lang}
    activeCategory="web"
  />
</BaseLayout>
