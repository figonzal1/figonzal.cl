---
import ClientSection from "@components/clients/ClientSection.astro";
import Particle from "@components/common/Particle.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { clientSeeder } from "src/utils/seeders/clientSeeder";

const lang = "en";

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://www.figonzal.cl/en",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Clients",
      item: "https://www.figonzal.cl/en/clients",
    },
  ],
};
---

<BaseLayout
  lang={lang}
  title="Clients | figonzal.cl"
  description="Professional projects and work Felipe González has developed for clients."
  canonical="https://www.figonzal.cl/en/clients"
  alternateEs="https://www.figonzal.cl/clientes"
  alternateEn="https://www.figonzal.cl/en/clients"
  breadcrumbJsonLd={breadcrumbJsonLd}
>
  <div class="h-0 w-0">
    <Particle />
  </div>
  <ClientSection
    title={["Professional", "Clients"]}
    clients={clientSeeder}
    lang={lang}
  />
</BaseLayout>
